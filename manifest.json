{
  "manifest_version": 3,
  "name": "Kainos TODO",
  "version": "1.0.0",
  "description": "AI-Assisted Coding Workshop — TODO Extension",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "host_permissions": [
    "https://api.anthropic.com/"
  ],
  "permissions": [
    "storage"
  ]
}
