{
  "schemaVersion": 1.0,
  "templateName": "story",
  "issueType": "story",
  "fields": {
    "title": {
      "required": true,
      "validators": [{ "type": "title" }]
    }
  },
  "description": {
    "sections": [
      {
        "id": "introduction",
        "hideHeader": true,
        "requiredForDraft": true,
        "requiredForReady": true,
        "validators": [{ "type": "as-i-want-so-that" }],
        "hintText": "*As the* {projectName} {PERSONA}\n*I want* {GOAL}\n*So that* {OUTCOME}"
      },
      {
        "id": "acceptance-criteria",
        "header": "Acceptance Criteria",
        "requiredForDraft": false,
        "requiredForReady": true,
        "validators": [
          {
            "type": "numbered-bullet-list",
            "prefix": "AC",
            "maxItems": 15
          }
        ],
        "hintText": "Use bullet points with AC01, AC02... Max 15 acceptance criteria."
      },
      {
        "id": "out-of-scope",
        "header": "Out of Scope",
        "requiredForDraft": false,
        "requiredForReady": false
      },
      {
        "id": "technical-notes",
        "header": "Technical Notes",
        "requiredForDraft": false,
        "requiredForReady": true
      },
      {
        "id": "testing-notes",
        "header": "Testing Notes",
        "requiredForDraft": false,
        "requiredForReady": true
      }
    ]
  }
}
