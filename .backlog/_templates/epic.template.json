{
  "schemaVersion": 1.0,
  "templateName": "epic",
  "issueType": "epic",
  "fields": {
    "title": {
      "required": true,
      "validators": [{ "type": "title" }]
    }
  },
  "description": {
    "sections": [
      {
        "id": "introduction",
        "hideHeader": true,
        "requiredForDraft": true,
        "requiredForReady": true,
        "validators": [{ "type": "as-i-want-so-that" }],
        "hintText": "*As the* {projectName} {PERSONA}\n*I want* {GOAL}\n*So that* {OUTCOME}"
      },
      {
        "id": "background",
        "header": "Background",
        "requiredForDraft": false,
        "requiredForReady": true,
        "hintText": "Background information about the epic"
      },
      {
        "id": "materials",
        "header": "Materials",
        "requiredForDraft": false,
        "requiredForReady": false,
        "hintText": "References to files on both internal project Confluence space or external links e.g. API docs"
      },
      {
        "id": "scope",
        "header": "Scope",
        "requiredForDraft": false,
        "requiredForReady": true,
        "hintText": "What is in scope for the epic"
      },
      {
        "id": "out-of-scope",
        "header": "Out of Scope",
        "requiredForDraft": false,
        "requiredForReady": false,
        "hintText": "What is out of scope for the epic"
      },
      {
        "id": "dependencies",
        "header": "Dependencies",
        "requiredForDraft": false,
        "requiredForReady": false,
        "hintText": "Dependencies with other stakeholders e.g. other NHS teams"
      }
    ]
  }
}
